[Unit]
Description=MediaAuto Bot Service
After=network.target

[Service]
Type=simple
User=mediaauto
WorkingDirectory=/opt/mediaauto
ExecStart=/opt/mediaauto/venv/bin/python /opt/mediaauto/src/worker_launcher.py
Restart=always
RestartSec=5
Environment=PYTHONPATH=/opt/mediaauto

[Install]
WantedBy=multi-user.target
